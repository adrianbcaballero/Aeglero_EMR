# Postgres (Docker)
POSTGRES_DB=aeglero_emr
POSTGRES_USER=aeglero
POSTGRES_PASSWORD=change_me

# Backend app settings
DATABASE_URL=postgresql+psycopg2://aeglero:change_me@db:5432/aeglero_emr
SECRET_KEY=change_me
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local dev only — slug used when Host header is localhost/127.0.0.1
# Production resolves slug from subdomain: sunrise-detox.aeglero.com → "sunrise-detox"
DEV_TENANT_SLUG=sunrise-detox

SESSION_TIMEOUT_MINUTES=15
MAX_FAILED_LOGINS=5
ACCOUNT_LOCKOUT_MINUTES=30
